# "local" (default) writes tickets into ../TurboFix-Tracker.xlsx, no credentials needed.
# "sheets" writes to a live Google Sheet - requires GOOGLE_SHEET_ID + GOOGLE_SERVICE_ACCOUNT_FILE below.
TICKET_STORE=local
TRACKER_XLSX_PATH=

GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_FILE=

# Set this to any string you choose; Meta calls GET /webhook with this token
# during setup and you must echo back hub.challenge only if it matches.
WHATSAPP_VERIFY_TOKEN=
# Long-lived access token for the WhatsApp Cloud API (Meta developer app).
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v20.0
# The Cloud API "from" number fan-out sends as (Meta phone_number_id, not the raw number).
WHATSAPP_PHONE_NUMBER_ID=

# Phase 3 fan-out - must match a template already approved in Meta Business Manager.
# Without WHATSAPP_ACCESS_TOKEN/WHATSAPP_PHONE_NUMBER_ID set, fan-out is skipped and
# tickets still log/summarize as normal.
WHATSAPP_TICKET_TEMPLATE_NAME=turbofix_new_ticket
WHATSAPP_TICKET_TEMPLATE_LANGUAGE=en_US

MEDIA_STORE_DIR=
SESSION_TTL_SECONDS=900

# Phase 4 (harden) - how often the background sweep fires a fallback fan-out for
# sessions that expired without ever being notified, and how long a Machines-tab
# read is cached before re-reading the tracker/Sheet.
SESSION_SWEEP_INTERVAL_SECONDS=60
MACHINES_CACHE_TTL_SECONDS=60

# AI layer (Phase 2) - transcription + summarization. Without this set, tickets
# still get logged, just without ai_summary/urgency filled in.
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_CHAT_MODEL=gpt-4.1-nano
